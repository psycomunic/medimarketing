# === Supabase ===
# Encontre estes valores no painel do Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Chave de serviço (NUNCA expor no client). Usada apenas em rotas de servidor/admin.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# === Contato / CTAs ===
# Número de WhatsApp no formato internacional, apenas dígitos (ex.: 5511999999999)
NEXT_PUBLIC_WHATSAPP=5511999999999
NEXT_PUBLIC_EMAIL_CONTATO=contato@medimarketing.com.br
